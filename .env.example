# AgentTrap Environment Variables (Template)
# Rename this file to .env and fill in your actual keys.

# Required: Google Gemini API Key
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX"

# Optional: Anthropic / OpenAI Keys
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# The default model to run evaluations with (Supports Gemini 2.x native styles)
DEFAULT_MODEL="gemini-2.5-flash"
